# Streamlit Cloud Secrets Template
# Copy this file to .streamlit/secrets.toml and fill in your API keys
# DO NOT commit secrets.toml to GitHub

GEMINI_API_KEY_1 = "your-gemini-api-key-1-here"
GEMINI_API_KEY_2 = "your-gemini-api-key-2-here"
GEMINI_API_KEY_3 = "your-gemini-api-key-3-here"
GROQ_API_KEY = "your-groq-api-key-here"
GITHUB_API_KEY = "your-github-api-key-here"
